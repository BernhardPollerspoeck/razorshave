# EditorConfig for Razorshave
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{json,yml,yaml,md}]
indent_size = 2

[*.{js,mjs,cjs,ts,jsx,tsx}]
indent_size = 2

[*.cs]
# Microsoft default C# conventions

# Namespace declarations
csharp_style_namespace_declarations = file_scoped:error

# var
csharp_style_var_for_built_in_types = true:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = true:suggestion

# Expression-bodied members
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_expression_bodied_properties = true:suggestion

# using
csharp_using_directive_placement = outside_namespace:error
dotnet_sort_system_directives_first = true

# Unused usings
dotnet_diagnostic.IDE0005.severity = warning

# Prefer readonly
dotnet_style_readonly_field = true:warning

# New lines
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true

# Indent
csharp_indent_case_contents = true
csharp_indent_switch_labels = true

# Spacing
csharp_space_after_cast = false
csharp_space_after_keywords_in_control_flow_statements = true

# Naming
dotnet_naming_rule.interface_should_be_prefixed.severity = warning
dotnet_naming_rule.interface_should_be_prefixed.symbols = interface_symbol
dotnet_naming_rule.interface_should_be_prefixed.style = interface_style
dotnet_naming_symbols.interface_symbol.applicable_kinds = interface
dotnet_naming_style.interface_style.capitalization = pascal_case
dotnet_naming_style.interface_style.required_prefix = I

dotnet_naming_rule.private_fields_should_be_camel_with_underscore.severity = warning
dotnet_naming_rule.private_fields_should_be_camel_with_underscore.symbols = private_field_symbol
dotnet_naming_rule.private_fields_should_be_camel_with_underscore.style = private_field_style
dotnet_naming_symbols.private_field_symbol.applicable_kinds = field
dotnet_naming_symbols.private_field_symbol.applicable_accessibilities = private
dotnet_naming_style.private_field_style.capitalization = camel_case
dotnet_naming_style.private_field_style.required_prefix = _
