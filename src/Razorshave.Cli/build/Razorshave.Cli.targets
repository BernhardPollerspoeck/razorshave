<Project>
  <!--
    Razorshave MSBuild integration. Imported automatically by consumers who
    install Razorshave.Cli as a NuGet package (NuGet places .targets files
    from the `build/` folder on the project's MSBuild graph). For local dev
    the target project can <Import> this file directly.

    Trigger: the custom "Razorshave" build configuration. Users opt in via
    `dotnet build -c Razorshave`; Debug and Release remain unaffected so
    Blazor Server dev loops don't pay the transpile cost.
  -->

  <PropertyGroup Condition="'$(Configuration)' == 'Razorshave'">
    <!-- Ensure the Razor source generator persists .razor.g.cs on disk so
         the transpiler can read them. Users can override if needed. -->
    <EmitCompilerGeneratedFiles Condition="'$(EmitCompilerGeneratedFiles)' == ''">true</EmitCompilerGeneratedFiles>

    <!-- URL prefix every emitted asset (CSS, favicon, the JS bundle) is
         rooted at. Default "/" emits /main.X.js, /app.css, etc. — works
         for SPAs deployed at the domain root. Override to "/myapp/" when
         deploying under a sub-path so deep-link requests still find
         the bundle. -->
    <RazorshaveBasePath Condition="'$(RazorshaveBasePath)' == ''">/</RazorshaveBasePath>

    <!-- Static <title> for index.html. Defaults to the assembly name so
         each project gets a sensible window title without explicit setup;
         per-page <PageTitle> components override this at runtime. -->
    <RazorshaveTitle Condition="'$(RazorshaveTitle)' == ''">$(AssemblyName)</RazorshaveTitle>
  </PropertyGroup>

  <!-- UsingTask picks up the compiled Razorshave.Cli assembly. The path is
       resolved relative to this .targets file so the import works from all
       three consumption modes:
         * NuGet package      → tasks/net10.0/razorshave.dll (packed explicitly)
         * Local dev Debug    → ../bin/Debug/net10.0/razorshave.dll
         * Local dev Release  → ../bin/Release/net10.0/razorshave.dll -->
  <UsingTask TaskName="Razorshave.Cli.RazorshaveTranspileTask"
             AssemblyFile="$(MSBuildThisFileDirectory)..\tasks\net10.0\razorshave.dll"
             Condition="Exists('$(MSBuildThisFileDirectory)..\tasks\net10.0\razorshave.dll')" />
  <UsingTask TaskName="Razorshave.Cli.RazorshaveTranspileTask"
             AssemblyFile="$(MSBuildThisFileDirectory)..\bin\Debug\net10.0\razorshave.dll"
             Condition="Exists('$(MSBuildThisFileDirectory)..\bin\Debug\net10.0\razorshave.dll')" />
  <UsingTask TaskName="Razorshave.Cli.RazorshaveTranspileTask"
             AssemblyFile="$(MSBuildThisFileDirectory)..\bin\Release\net10.0\razorshave.dll"
             Condition="Exists('$(MSBuildThisFileDirectory)..\bin\Release\net10.0\razorshave.dll')" />

  <Target Name="RazorshaveTranspile"
          AfterTargets="Build"
          Condition="'$(Configuration)' == 'Razorshave'">
    <Message Importance="high" Text="Razorshave: triggering transpile for $(MSBuildProjectName) (base: $(RazorshaveBasePath), title: $(RazorshaveTitle))" />
    <RazorshaveTranspileTask ProjectDirectory="$(MSBuildProjectDirectory)"
                             Configuration="$(Configuration)"
                             BasePath="$(RazorshaveBasePath)"
                             Title="$(RazorshaveTitle)" />
  </Target>

</Project>
